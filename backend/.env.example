# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/hopes-donation

# Auth (প্রোডাকশনে দীর্ঘ র্যান্ডম স্ট্রিং ব্যবহার করুন)
JWT_SECRET=replace-with-long-random-secret-min-32-chars

# CORS — comma-separated origins (প্রোডাকশনে বাধ্যতামূলক, যেমন https://app.vercel.app)
CORS_ORIGINS=http://localhost:3000

# রেট লিমিট (ঐচ্ছিক)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=400
# AUTH_RATE_LIMIT_MAX=30

# অ্যাডমিন সিড (প্রথম চালুতে একবার — ঐচ্ছিক)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PHONE=01700000000
SEED_ADMIN_PASSWORD=change-me-strong
SEED_ADMIN_NAME=অ্যাডমিন

# OTP মক (ডেভ)
# MOCK_OTP_FIXED=123456
# MOCK_OTP_ALWAYS_OK=true

# (ডেমো/টেস্ট) প্রোডাকশনে API রেসপন্সে OTP দেখাতে চাইলে
# SHOW_DEV_OTP_IN_RESPONSE=true
